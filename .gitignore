# ------------------------------------
# UNIVERSAL / OS / EDITOR FILES
# ------------------------------------
# macOS system files
.DS_Store

# Windows system files
Thumbs.db

# Visual Studio Code settings
.vscode/

# ------------------------------------
# TOP-LEVEL CACHE / TEMP / LOGS
# ------------------------------------
# Testing cache folders (catches the root-level folder you saw)
.pytest_cache/
test_cache/

# Python bytecode/compiled files (in case they appear outside backend/)
__pycache__/
*.pyc

# Node package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build and artifact directories (common defaults)
/dist/
/build/

# Local environment variables and sensitive configuration
.env
.env.local